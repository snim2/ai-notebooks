#!/bin/bash

set -o errexit
set -o nounset

echo "===> Starting Ollama..."

# Start Ollama in background if not running
if ! pgrep -x "ollama" > /dev/null
then
  ollama serve 
  sleep 2
fi

echo "===> Pulling model (if needed)..."
ollama pull qwen2.5-coder:7b

echo "===> Ollama ready at http://localhost:11434"
